{
  "name": "balance-restore",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [{
    "binding": "DB",
    "database_name": "balance-restore-db",
    "database_id": "COPY_YOUR_EXISTING_D1_DATABASE_ID_HERE"
  }],
  "vars": {
    "ADMIN_EMAIL": "COPY_YOUR_ADMIN_EMAIL_HERE"
  }
}
